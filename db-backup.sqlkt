INSERT INTO `UserReply` VALUES ('国内','货物状态','Dear Bryan  这票货刚刚到港，尚未上火车。',1),('上家','货物状态','Hi  Please update status of this shipment. Thanks!',2),('国内','各项费用','Dear Bryan  这票收到上家费账单一张，麻烦确认是否需要支付，以及由哪方支付，多谢！\r\n    ',3),('AP','各项费用','Hi Krystal  金额无误，已经录入，请帮忙支付，多谢！',4),('上家','各项费用','Good Morning  CoLoader fee is paid.\r',5),('收货人','货物状态','Hi Please reply to the Email I sent you. Otherwise I have on idea about which shipment you are talking about. \r\n    ',6),('收货人','清关相关','Hi This shipment is on rail. ETA  Please advise your broker to submit and clear customs accordingly. Thanks!\r\n    ',7),('清关代理','清关相关','Hi Shirley   CC Draft is confirmed. This shipment is on rail. ETA  Please submit and clear customs accordingly. Thanks!\r\n\r\n    ',8),('清关代理','清关相关','Hi This shipment is on floor. Please submit and clear customs ASAP. Thanks!\r',9),('国内','各项费用','Dear Bryan 这票货刚刚落地。其中有    个板要换，请确认换板费USD ，由哪方支付，多谢！',10),('国内','清关相关','Dear Bryan  请尽快提供此票的箱单发票。另外请确认这票的条款是DDP还是DDU。多谢！',11),('海关仓库','派送相关','Thank you so much. Please arrange delivery ASAP.\r',12),('国内','货物状态','Dear Bryan 这票货柜已经抵达铁路终端，海关仓库还没有提柜。\r\n    ',13),('国内','货物状态','Dear Bryan 还没有到温哥华的ETA。',14),('国内','派送相关','Dear Bryan  已经清关完毕，预计本周末前派送。\r\n    ',15),('国内','放货','Dear Bryan   这票已经上火车。ETA　，请确认是否可以放货，多谢！',16),('国内','派送相关','Dear 这票货已经派送完毕，正在等POD。\r\n    ',17),('清关代理','清关相关','Hi Shirley   CC Draft is confirmed. Please arrange submit accordingly.Thanks!\r\n    ',18),('上家','放货','Hi Well noted with thanks. Please provide us PU#, once it is available. Thanks!',19),('收货人','清关相关','Hi Your new shipment is on the way. HBL CIPL CC Draft are attached. Please confirm ASAP. Thanks!\r\n    ',20),('AP','各项费用','Hi Krystal  这笔上家费用已经由收货方支付，并录入。请帮忙支付，DUE 2PM。多谢！',21),('国内','各项费用','Dear Bryan  这票货已经送达，相关费用及文件详见附件（账单 CN POD）。 谢谢！这票的DOCK FEE是USD65，此前没有收到贵司的CN。 请知悉。***请于24小时内回复此邮件确认费用无误，如我司未收到回复确认，则默认此单确认无误并转交至我司财务部对账***\r\n    ',22),('卡车司机','派送相关','Good Morning  Please provide POD, once it is available. Thanks！',23),('国内','清关相关','Hi Carey  税单草稿详见附件，请尽快确认。',24),('海关仓库','各项费用','Please send us dock fee invoice. We will pay by EMT. Thanks!\r\n    ',25),('AP','各项费用','Hi Krystal  这票DOCK FEE 已经录入，由国内美设支付，请帮忙尽快支付。DUE 4月5日 2 PM。多谢！\r\n    ',26),('收货人','清关相关','Import business number should be 9 digits begin with 1,7,8 and followed by RM0001 or RM0002 . Please confirm.\r\n    ',27),('收货人','货物状态','Please fill your position in company on the place red-lined.\r\n    ',28),('收货人','清关相关','Your new shipment is on the way. Please forward all the files attached to your broker to clear customs. I\'ll provide ETA, once it is on rail. Thanks!\r\n    ',29),('国内','清关相关','Dear Bryan  请尽快提供此票的箱单发票。多谢！\r\n    ',30),('收货人','各项费用','Hi  Please send us screen shot of payment for our accountant to confirm. Thanks！\r\n    ',31),('收货人','清关相关','您的税单草稿详见附件，请尽快确认，多谢!',32),('上家','放货','Good Morning  This container is on rail. Please provide PU# ASAP. Thanks!\r\n    ',33),('国内','货物状态','Hi Carey 这个整柜刚刚上火车。ETA TORONTO 2023-04-11。请告知哪些需要扣货。多谢！\r\n    ',34),('卡车司机','派送相关','Please confirm these containers are returned and provide EIR, once available. Thanks!\r\n    ',35),('AP','各项费用','Hi Krystal   麻烦帮把后台中这票账单void掉。多谢！\r\n    ',36),('收货人','清关相关','Hi Your CC Draft is attached. Please confirm ASAP. Please feel free to contact me, if you have any question about it. Thanks!\r\n    ',37),('海关仓库','各项费用','Good Morning Please send us dock fee invoice. Thanks!\r\n    ',38),('收货人','清关相关','Hi 您的这票新货已经在路上了。税单草稿，提单和箱单发票详见附件，请尽快确认。多谢！\r\n    ',39),('收货人','货物状态','Hi I\'ll provide ETA, once it is on rail. Thanks!\r\n    ',40),('上家','各项费用','Good Morning Could you please provide Exam notice, as it is required by our oversea? Thanks!',41),('国内','货物状态','Dear Bryan 这票货柜即将抵达铁路终端。\r\n    ',42),('国内','货物状态','Dear Bryan  这票货已经上火车，ETA 。请确认是否可以放货，多谢！\r\n    ',43),('收货人','派送相关','Hi I\'ll book appointment with you, once it is available.\r\n    ',44),('上家','放货','Hi This shipment is on floor. Please release this shipment to K Trans. Thanks!\r\n    ',45),('国内','货物状态','Dear Bryan 请提供收货人的联系方式，电邮电话。多谢！\r\n    ',46),('收货人','清关相关','Hi Please add your import business number after your company name and fill your position in your company above your signature red-lined.\r\n    ',47),('收货人','派送相关','Hi Now the question is your shipment is overweight for tailgate. The maximum capacity for tailgate is 700KGS. There is 2 pallets with 1694.000 KGS together. Is it possible for you to rent a forklift to unload or you can ask your staff to break the wooden case and take some cargo out until them can  be unloaded with tailgate? Please confirm ASAP. Thanks!\r\n    ',48),('海关仓库','放货','Good Morning Dock fee is paid. Please release this shipment to K Trans. Thanks!\r\n    ',49),('国内','各项费用','Dear Bryan  由于收货人没有loading dock，需要尾板卸货，尾板费USD75，由哪方支付，请尽快确认。多谢！\r\n    ',50),('国内','派送相关','Hi Carey 联系了收货人很多次，电话都打不通。麻烦确认一下电话号码或者发送收货人电子邮箱地址过来，多谢！\r\n    ',51),('收货人','各项费用','As you do not have a loading dock,  we need to use tailgate to offload cargo for you. There is tailgate fee need to be charged.\r\n    ',52),('AR','各项费用','Hi Gavin 请帮忙确认这笔支付是否到账，多谢！\r\n    ',53),('国内','各项费用','Hi Carey 刚刚收到海关仓库通知。这票货被海关查验。查验费以及后续可能产生的仓储费由哪方支付，请尽快确认。多谢！\r\n    ',54),('国内','货物状态','Dear Bryan 这票货已经抵达海关仓库，但还没有拆柜落地。\r\n    ',55),('国内','货物状态','Dear Bryan 这票货即将到港。\r\n    ',56),('收货人','清关相关','Hi Your shipment is on floor. Please clear customs ASAP. Thanks!\r\n    ',57),('清关代理','清关相关','Hi This shipment is on Rail. ETA TORONTO 2023-05-25 .  Please submit and clear customs accordingly. Thanks!\r\n    ',58),('清关代理','清关相关','Hi Shirley CC Draft is confirmed. This shipment is not on rail yet. Please submit and clear customs accordingly. Thanks!\r\n    ',59),('上家','各项费用','Hi Dyno Our oversea just advised us they will pay you directly. Please confirm. Thanks！\r\n    ',60),('上家','各项费用','Good Morning Co-loader fee is paid. Please release this shipment to K Trans. Thanks!\r\n    ',61),('国内','派送相关','Dear Bryan 请提供此票货的具体尺寸。多谢！\r\n    ',62),('收货人','各项费用','Hi This shipment is delivered. Please provide your company name and mail address. We will make refund by cheque. Thank you so much!\r\n    ',63),('收货人','货物状态','It is arrived customs warehouse, but not be destuffed and on floor yet.\r\n    ',64),('卡车司机','各项费用','Hi Roben 已经发送给公司财务。我们会尽快支付，多谢！\r\n    ',65),('收货人','清关相关','Hi Import business number is different from your business number. Please confirm with your accountant or CRA.\r\n    ',66),('国内','清关相关','Dear Bryan 因为这票是“CNF”，所以请提供运费的金额，以便我们在清关时，从货物总值中减去运费，以降低税费，多谢！\r\n    ',67),('上家','各项费用','Hi Would you mind providing us an invoice charging with CAD? Thanks!\r\n    ',68),('国内','清关相关','Dear Bryan 麻烦提供一下这票货的ON BOARD DATE。 多谢！\r\n    ',69),('卡车司机','派送相关','Good Morning This container is ready for pickup. Please pickup and deliver as booked. Thank you so much!\r\n    ',70),('清关代理','清关相关','Hi May Please help to apply import business number for this client. POA is attached. Thanks!\r\n    ',71),('卡车司机','派送相关','Good Morning Please confirm this container is delivered and returned and provide POD, EIR, once it is available. Thanks！\r\n    ',72),('上家','各项费用','Hi Dyno Our oversea just advised us this colloader fee is cancelled. Please confirm. Thanks！\r\n    ',73),('上家','清关相关','Hi  Please provide Emanifest and Closemessage of this shipment. HBL is attached. Thanks!\r\n    ',74),('国内','清关相关','Hi Carey 请提供此票的Emanifest 和Closemessage，多谢！\r\n    ',75),('国内','货物状态','Dear Bryan 这票已经清关完毕，并已经提货，因为是长途派送，暂时未收到POD。',76),('收货人','放货','Hi   This shipment is customs cleared and ready for pickup. Please provide the name of driver or title of the trucker whom I will release to. Thanks!\r\n    ',77),('国内','货物状态','Dear Bryan 这票已经清关完毕，并已经通知收货方尽快提货。',78),('国内','货物状态','Dear Bryan  这票已经清关完毕，近期安排派送。\r\n    ',79),('国内','货物状态','Dear Bryan 这票已经清关完毕，正在等待收货人支付税费，收到税费后，我司会近期安排派送。\r\n    ',80),('国内','各项费用','Hi Crystal 这票的费用如何分配? 是DDU还是 DDP，请告知，多谢！\r\n    ',81),('国内','各项费用','Hi 请确认这票货的费用如何分配，是DDU还是DDP？另外请尽快提供E-manifest和Closemessage。多谢！',82),('国内','清关相关','Dear Bryan 已经拨打收货人电话多次，均无人接听。麻烦提供一下收货人的电子邮箱和其他电话联系方式，多谢！\r\n    ',83),('收货人','清关相关','Hi Your new shipment is on the way. Please advise your broker to clear customs. We K trans will take care of delivery. I\'ll provide ETA, once it is on rail. Thanks! Please confirm your delivery address is :\r\n    ',84),('卡车司机','派送相关','Hi，This container is empty. Please arrange pickup and return ASAP. Thanks!',85),('卡车司机','各项费用','Hi Please confirm this is the final invoice and no more waiting time applied. Thanks!\r\n    ',86),('收货人','各项费用','Hi Tan\r\n您的押金返款Credit notes 详见附件，请提供您的公司名头，以及邮寄地址。返款将以邮寄支票的形式进行。多谢！\r\n\r\nHi Krystal\r\n请根据收货人提供信息尽快返款，Credit notes 详见附件。多谢！\r\n    ',87),('收货人','货物状态','Hi   Please confirm you are the consignee of this shipment. HBL CIPL is attached. This is our freehand shipment. So you need to ask your broker to clear customs and pickup it by your trucker. Thanks！\r\n    ',88),('上家','清关相关','Good Morning This container is on rail. Please provide E-manifest and Closemessage ASAP. Thanks!\r\n    ',89),('国内','货物状态','Good Morning Please confirm this shipment is delivered or provide us ETA. Thanks!\r\n    ',90),('清关代理','清关相关','Hi This is our freehand shipment. All the files related are attached. Please clear cusotms and arrange delivery accordingly. Please feel free to let me know, if you have any question about this shipment. Thank you so much!\r\n    ',91),('AP','各项费用','Hi Krystal 这笔税费收货人已经支付，并录入系统，请尽快给William出支票，多谢！',92),('收货人','派送相关','Hi Please confirm you can receive this shipment on Sep 7th between 2-4PM. Thanks!\r\n    ',93),('国内','各项费用','Hi Carey   这票货已经送达，相关费用及文件详见附件（账单, POD）。 请尽快确认并支付。谢谢！***请于24小时内回复此邮件确认费用无误，如我司未收到回复确认，则默认此单确认无误并转交至我司财务部对账***\r\n    ',94),('收货人','货物状态','Hi  This shipment is on floor. Delivery will be made soon. I\'ll book appointment with you ahead, once it is available. Thanks!\r\n    ',95),('国内','清关相关','Dear Bryan 麻烦提供此票收货人的联系方式，电话以及电子邮箱。多谢！\r\n    ',96),('上家','放货','Hi  This shipment is on floor. Please confirm this shipment is released  to K Trans. Thanks!\r\n    ',97),('卡车司机','派送相关','Good Morning Please provide POD or ETA, once it is available . Thanks！\r\n    ',98),('收货人','放货','Good Morning Ray Payment is confirmed. Please provide driver\'s name or trucker\'s title, we can release to. Thanks!\r\n    ',99),('国内','派送相关','Dear Bryan 这票已经送达，正在等POD。\r\n    ',100),('收货人','放货','Hi  您的货物已经落地，LFD 是11月2日，请尽快提供提货司机姓名或者 公司名称。\r\n提货地址：HUNA 海关仓库，420 Parkhurst Square, Brampton, ON. L6T 5W1.\r\n货物信息：CCN：8C43T302469H003\r\n12 个托盘 	3731.00 KGS	27.400 CBM\r\n    ',101),('AP','各项费用','Hi Krystal 这笔上家费用将由国内华迪支付，已经录入。请帮忙尽快支付，LFD 12月20日 2PM。多谢！\r\n    ',102),('卡车司机','派送相关','Good Morning Please confirm this container is delivered and returned and provide POD, EIR, invoice， once they are available. Thanks！\r\n    ',103),('收货人','清关相关','Hi Your new shipment is on the way. Please forward all the files attached to your broker to clear customs. I\'ll provide ETA, once it is on rail. We Ktrans will take care of delivery. Thanks! \r\n    ',104),('清关代理','清关相关','Hi Shirley CC Draft is confirmed.This shipment is on floor. Please submit and clear customs ASAP. Thanks!\r\n\r\n\r\n    ',105),('海关仓库','各项费用','Good Morning Please send us invoice of dock fee for shipment with CCN as following:\r\n    ',106),('海关仓库','各项费用','Good Morning Please send us invoices of dock fee for shipments with CCN as following:\r\n    ',107),('KATHIE','派送相关','Hi Kathie    华迪拼柜货中的一票。从Huna海关仓库，420 Parkhurst Square, Brampton, ON. L6T 5W1. 送至   746 Richmond St, London, ON N6A 3H3   单程173公里        货物信息 ：1 PLT，1.97CBM，509KGS      需要尾板卸货  底价：                  派送费收货人支付。请帮忙尽快报价。多谢！\r\n    ',108),('收货人','派送相关','您这票货的提货地址是：420 Parkhurst Square, Brampton, ON. L6T 5W1.  CCN：8C43T302790H003  货物信息：8个板 1626.2KGS  22.86cbm  请付款之后尽快告知提货卡车公司名称或司机姓名。\r\n    ',109),('海关仓库','各项费用','Hi  Please send us dock fee invoice of this shipment with CCN as following. Thanks!\r\n    ',110),('国内','派送相关','Good Morning  Your shipment is ready for delivery. Please confirm you can receive it on Apr 23th  at 50 CHARLTON AVE EAST HAMILTON,ON,L8N 4A6,CANADA with loading dock available, curbside delivery with tailgate needed.\r\n    ',111),('收货人','派送相关','Good Morning  Your shipment is ready for delivery. Please confirm you can receive it on Apr 23th  at 50 CHARLTON AVE EAST HAMILTON,ON,L8N 4A6,CANADA with loading dock available, curbside delivery with tailgate needed.\r\n    ',112),('收货人','派送相关','Good Morning Your shipment is ready for delivery. Please confirm you can receive it on Apr 23th  between 10-12pm  at 50 CHARLTON AVE EAST HAMILTON,ON,L8N 4A6,CANADA with loading dock available, curbside delivery with tailgate needed.\r\n    ',113),('收货人','清关相关','CARM is coming! All importers need to be registered. Please call 1-800-959-8886 to register.   https://ccp-pcc.cbsa-asfc.cloud-nuage.canada.ca/en/assets/pdfs/onboarding/en/CARM_Client_Portal_Onboarding_Guide_Importers_April_2021.pdf   How to create login credentials and a user account in the CARM Client Portal - YouTube\r\n    ',114),('收货人','清关相关','Hi 请根据附件中POA模板，填写，并回复至本邮件。另外需要贵司提供邮箱和密码，因为申请CARM时需要进入邮箱激活。激活后贵司即可重新更新密码。多谢！\r\n    ',115),('收货人','清关相关','Hi  我司代为申请CARM费用为USD250. 请根据附件中POA模板，填写，并回复至本邮件。另外需要贵司提供邮箱和密码，因为申请CARM时需要进入邮箱激活。激活后贵司即可重新更新密码。多谢！\r\n    ',116),('国内','各项费用','\r\n  另，因为近期多伦多铁路终端繁忙，如果在派送过程中出现提柜，还柜，以及卸货等待费和箱使费，将向贵司收取，请知悉。',117),('国内','各项费用','Dear Rita  因为近期多伦多铁路终端繁忙，如果在派送过程中出现提柜，还柜，以及卸货等待费和箱使费，根据我司规定需要提前收取收货人押金CAD1500， 收货人拒绝支付，麻烦贵司帮协调一下，多谢！\r\n    ',118),('国内','放货','Hi Carey 请尽快提供电放文件给上家，以便上家发放PU#。多谢！\r\n    ',119),('国内','各项费用','Hi 因为这票是周末抵达，铁路终端免费仓储时间只有一天。为避免高额仓储费，我司会根据需要提前安排prepull。prepull费用USD150，由哪方支付，请确认。另外由于多伦多铁路终端拥堵提柜和还柜过程中，有可能产生等待费，如有，哪方支付？如果是收货人支付，我司需要提前收取收货人押金CAD1000,请确认，多谢！\r\n    ',120),('国内','各项费用','这票的e-Manifest修改费USD15， 由哪方支付，请确认。多谢！\r\n    ',121),('收货人','各项费用','Hi\n\nYour shipment is on floor. Invoice is attached. Please make payment ASAP. \n\nAttached please find invoice INT008803 , in an amount of CAD$266.14  and please kindly settle this payment. Pls make a payment by E-transfer to email address:\n \naccountant@ktranslogistics.com\n\nPlease write down your shipment\'s file number T303042 in \'Memo\'when arrange payment.\n\n\nPlease reply payment receipt to us， so our accountant can check payment in time.\n\nPlease confirm your deliver address is 125 Ironside Dr, Brampton, ONTARIO L7A 0H3 curbside with tailgate needed.\n\n\nBest Regards\n',122);
/*!40000 ALTER TABLE `UserReply` ENABLE KEYS */;
UNLOCK TABLES;

--
-- Table structure for table `Warehouse`
--

DROP TABLE IF EXISTS `Warehouse`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `Warehouse` (
  `warehouse_id` int NOT NULL AUTO_INCREMENT,
  `address` varchar(50) DEFAULT NULL,
  `city` varchar(20) DEFAULT NULL,
  `company` varchar(50) DEFAULT NULL,
  `hours` char(50) DEFAULT NULL,
  `phone` varchar(25) DEFAULT NULL,
  `Email` varchar(100) DEFAULT NULL,
  `website` varchar(100) DEFAULT NULL,
  `account` varchar(50) DEFAULT NULL,
  `password` varchar(50) DEFAULT NULL,
  `inquiry_Email` varchar(50) DEFAULT NULL,
  `remark` varchar(200) DEFAULT NULL,
  PRIMARY KEY (`warehouse_id`)
) ENGINE=InnoDB AUTO_INCREMENT=35 DEFAULT CHARSET=utf8mb3;
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `Warehouse`
--


INSERT INTO `CompanyNews` VALUES (1,'Kathie','未关单的file 不要在月统计中','Dear ALL；\r\n大家好，再次提醒下没有关单的file 请他们不要计算在月统计中。\r\n请一定注意一定关单的才统计','2024-08-05 03:38:27'),(2,'Tina','CP 联系方式更新','CP 联系方式：cs_intermodal@cpr.ca,International_COG@cpr.ca','2024-08-05 03:40:23'),(3,'Anna','【重要】操作系统关单','Hi Operation Team，\r\n\r\n请检查未关单的file，如没有问题的单子请关单。\r\n如遇到关单问题，或者需要关单但是不能关单，请将FILE# 邮件给 kathie<kathie@ktranslogistics.com>； anna@ktranslogistics.com ; import@ktranslogistics.com\r\n\r\n查询未关单步骤：\r\n OP：选择操作名字\r\n Status： 选择Open\r\nSort By： Ascending\r\n根据货物ETA 时间查询','2024-08-05 03:41:24'),(4,'Gavin','加拿大公司财务要求操作注意事项 2024-06-24','在原来的文件中增加了以下内容：\r\n\r\n如果货物已经清出关，脱离我们的监管仓库，和本地客人的收款的服务项目中都应加上相对应的 GST/HST(BC 省是\r\n5% GST, ON 省是 13% HST)','2024-08-05 03:43:15');
/*!40000 ALTER TABLE `CompanyNews` ENABLE KEYS */;
UNLOCK TABLES;

